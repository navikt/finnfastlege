  "author": "Team DigiSyfo <digisyfo@nav.no>",
  "type": "module",
  "main": "index.tsx",
  "scripts": {
    "start": "pnpm msw:update && vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc --build ./server/tsconfig.json",
    "test": "vitest run",
    "lint-and-typecheck": "pnpm lint:check && pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:write": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "msw:update": "msw init . --save"
  },
  "dependencies": {
    "@grafana/faro-react": "1.19.0",
    "@grafana/faro-web-sdk": "1.19.0",
    "@grafana/faro-web-tracing": "1.19.0",
    "@navikt/ds-css": "7.33.2",
    "@navikt/ds-react": "7.33.2",
    "@navikt/pino-logger": "5.0.0",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-query-devtools": "5.100.11",
    "@types/express": "4.17.21",
    "@types/express-http-proxy": "1.6.3",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/styled-components": "5.1.25",
    "axios": "1.16.1",
    "classnames": "2.5.1",
    "core-js": "3.49.0",
    "dotenv": "17.4.2",
    "express": "4.22.1",
    "express-http-proxy": "1.6.3",
    "http-proxy": "1.18.1",
    "https-proxy-agent": "5.0.1",
    "pino": "10.3.1",
    "prom-client": "14.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "regenerator-runtime": "0.14.1",
    "styled-components": "5.3.5"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jsdom": "16.2.14",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "jsdom": "26.1.0",
    "jsdom-global": "3.0.2",
    "msw": "2.14.6",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "pino-pretty": "13.1.3",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.7"
